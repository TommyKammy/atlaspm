{
  "name": "atlaspm",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0 <21.0.0",
    "pnpm": ">=9.0.0 <10.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "type-check": "pnpm -r --if-present type-check",
    "type-check:core-api": "pnpm --filter @atlaspm/core-api type-check",
    "type-check:web-ui": "pnpm --filter @atlaspm/web-ui type-check",
    "type-check:collab-server": "pnpm --filter @atlaspm/collab-server type-check",
    "e2e:up": "./scripts/e2e-up.sh",
    "e2e": "./scripts/run-e2e.sh",
    "e2e:down": "./scripts/e2e-down.sh",
    "e2e:rebuild": "E2E_REBUILD=1 ./scripts/run-e2e.sh",
    "db:migrate": "pnpm --filter @atlaspm/core-api prisma:migrate",
    "db:seed": "pnpm --filter @atlaspm/core-api db:seed"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "eslint": "^9.20.1",
    "prettier": "^3.5.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1"
  }
}
