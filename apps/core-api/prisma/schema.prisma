generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectRole {
  ADMIN
  MEMBER
  VIEWER
}

enum WorkspaceRole {
  WS_ADMIN
  WS_MEMBER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  projects    Project[]
  memberships WorkspaceMembership[]
  invitations Invitation[]
}

model User {
  id          String   @id
  email       String?
  displayName String?
  status      UserStatus @default(ACTIVE)
  lastSeenAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspaceMemberships WorkspaceMembership[]
  projectMemberships   ProjectMembership[]
  invitationsCreated   Invitation[] @relation("InvitationCreatedBy")
}

model WorkspaceMembership {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(WS_MEMBER)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Invitation {
  id              String   @id @default(uuid())
  workspaceId     String
  email           String
  role            WorkspaceRole @default(WS_MEMBER)
  tokenHash       String   @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdByUserId String
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User @relation("InvitationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, email])
}

model Project {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberships ProjectMembership[]
  sections    Section[]
  tasks       Task[]
  rules       Rule[]
  webhooks         Webhook[]
  customFields     CustomFieldDefinition[]
}

model ProjectMembership {
  id          String      @id @default(uuid())
  projectId   String
  userId      String
  role        ProjectRole
  createdAt   DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Section {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  position    Int
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, position])
}

model Task {
  id             String     @id @default(uuid())
  projectId       String
  sectionId       String
  title          String
  description    String?
  descriptionDoc Json?      @map("description_doc")
  descriptionText String?   @map("description_text")
  descriptionUpdatedAt DateTime? @map("description_updated_at")
  descriptionVersion Int    @default(0) @map("description_version")
  status         TaskStatus @default(TODO)
  progressPercent Int       @default(0)
  priority       Priority?
  assigneeUserId String?
  startAt        DateTime?
  dueAt          DateTime?
  tags           String[]   @default([])
  completedAt    DateTime?
  position       Int
  version        Int        @default(1)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  comments TaskComment[]
  mentions TaskMention[]
  attachments TaskAttachment[]
  customFieldValues CustomFieldValue[]

  @@index([projectId, sectionId, position])
}

model TaskComment {
  id           String   @id @default(uuid())
  taskId       String   @map("task_id")
  authorUserId String   @map("author_user_id")
  body         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("task_comments")
}

model TaskMention {
  id              String   @id @default(uuid())
  taskId          String   @map("task_id")
  mentionedUserId String   @map("mentioned_user_id")
  sourceType      String   @map("source_type")
  sourceId        String   @default("") @map("source_id")
  createdAt       DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, sourceType, sourceId])
  @@unique([taskId, mentionedUserId, sourceType, sourceId])
  @@map("task_mentions")
}

model TaskAttachment {
  id             String   @id @default(uuid())
  taskId         String   @map("task_id")
  uploaderUserId String   @map("uploader_user_id")
  fileName       String   @map("file_name")
  mimeType       String   @map("mime_type")
  sizeBytes      Int      @map("size_bytes")
  storageKey     String   @map("storage_key")
  uploadToken    String?  @map("upload_token")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("task_attachments")
}

model Rule {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  templateKey String
  definition  Json?
  enabled     Boolean  @default(true)
  cooldownSec Int      @default(60)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    RuleRun[]

  @@unique([projectId, templateKey])
}

model RuleRun {
  id            String   @id @default(uuid())
  ruleId         String
  taskId         String
  changed        Boolean
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  correlationId String

  rule Rule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, taskId, startedAt])
}

model AuditEvent {
  id            String   @id @default(uuid())
  actor         String
  entityType    String
  entityId      String
  action        String
  beforeJson    Json?
  afterJson     Json?
  correlationId String
  createdAt     DateTime @default(now())

  @@index([entityType, entityId, createdAt])
}

model OutboxEvent {
  id            String   @id @default(uuid())
  type          String
  payload       Json
  correlationId String
  createdAt     DateTime @default(now())
  deliveredAt   DateTime?

  @@index([type, createdAt])
}

model Webhook {
  id          String   @id @default(uuid())
  projectId   String
  targetUrl   String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}


model CustomFieldDefinition {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  name        String
  fieldType   String   @map("field_type")
  options     Json?
  config      Json     @default("{}")
  position    Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  values  CustomFieldValue[]

  @@index([projectId])
  @@index([projectId, isActive])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id                String @id @default(uuid())
  fieldDefinitionId String @map("field_definition_id")
  taskId            String @map("task_id")
  value             Json
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  fieldDefinition CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  task            Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([fieldDefinitionId, taskId])
  @@index([fieldDefinitionId])
  @@index([taskId])
  @@map("custom_field_values")
}