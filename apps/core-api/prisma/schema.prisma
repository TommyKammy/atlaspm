generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectRole {
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatusHealth {
  ON_TRACK
  AT_RISK
  OFF_TRACK
}

enum GoalStatus {
  NOT_STARTED
  ON_TRACK
  AT_RISK
  OFF_TRACK
  COMPLETED
}

enum CapacityScheduleSubjectType {
  WORKSPACE
  USER
}

enum IntegrationProviderKind {
  SLACK
}

enum IntegrationConnectionStatus {
  PENDING
  ACTIVE
  ERROR
  DISCONNECTED
}

enum IntegrationCredentialKind {
  ACCESS_TOKEN
  REFRESH_TOKEN
  API_TOKEN
  SIGNING_SECRET
}

enum IntegrationSyncStatus {
  IDLE
  RUNNING
  SUCCEEDED
  FAILED
}

enum IntegrationMappingDirection {
  IMPORT
  EXPORT
  BIDIRECTIONAL
}

enum WorkspaceRole {
  WS_ADMIN
  WS_MEMBER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum TaskType {
  TASK
  MILESTONE
  APPROVAL
}

enum TaskApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DependencyType {
  BLOCKS
  BLOCKED_BY
  RELATES_TO
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  BOOLEAN
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  projects    Project[]
  goals       Goal[]
  memberships WorkspaceMembership[]
  invitations Invitation[]
  portfolios  Portfolio[]
  capacitySchedules CapacitySchedule[]
  timeOffEvents TimeOffEvent[]
  integrationProviderConfigs IntegrationProviderConfig[]
}

model User {
  id          String   @id
  email       String?
  displayName String?
  status      UserStatus @default(ACTIVE)
  lastSeenAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspaceMemberships WorkspaceMembership[]
  projectMemberships   ProjectMembership[]
  invitationsCreated   Invitation[] @relation("InvitationCreatedBy")
  notifications        InboxNotification[]
  triggeredNotifications InboxNotification[] @relation("NotificationTriggeredBy")
  dashboards           Dashboard[]
  reminders            TaskReminder[]
  reminderPreference   UserReminderPreference?
  statusUpdates        ProjectStatusUpdate[]
  createdForms         Form[]
  taskApprovals        TaskApproval[]
  timeLogs             TaskTimeLog[]
  timelinePreferences  ProjectTimelinePreference[]
  viewPreferences      ProjectViewPreference[]
  savedViews           ProjectSavedView[]
  taskFollows          TaskFollower[]
  projectFollows       ProjectFollower[]
  ownedGoals           Goal[]
  capacitySchedules    CapacitySchedule[]
  timeOffEvents        TimeOffEvent[]
  integrationProviderConfigsCreated IntegrationProviderConfig[] @relation("IntegrationProviderConfigCreatedBy")
  integrationProviderConfigsUpdated IntegrationProviderConfig[] @relation("IntegrationProviderConfigUpdatedBy")
}

model IntegrationProviderConfig {
  id               String                    @id @default(uuid())
  workspaceId      String                    @map("workspace_id")
  provider         IntegrationProviderKind
  key              String
  displayName      String                    @map("display_name")
  status           IntegrationConnectionStatus @default(PENDING)
  settings         Json?                     @map("settings")
  createdByUserId  String                    @map("created_by_user_id")
  updatedByUserId  String?                   @map("updated_by_user_id")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")

  workspace        Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy        User                      @relation("IntegrationProviderConfigCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy        User?                     @relation("IntegrationProviderConfigUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  credentials      IntegrationCredential[]
  syncStates       IntegrationSyncState[]
  entityMappings   IntegrationEntityMapping[]

  @@unique([workspaceId, key])
  @@index([workspaceId, provider, status])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("integration_provider_configs")
}

/// Plaintext secrets must never be persisted. Store an encrypted ciphertext or
/// an external secret reference plus a redacted preview for audit-safe reads.
model IntegrationCredential {
  id                String                    @id @default(uuid())
  providerConfigId  String                    @map("provider_config_id")
  kind              IntegrationCredentialKind
  secretRef         String?                   @map("secret_ref")
  encryptedValue    String?                   @map("encrypted_value")
  redactedValue     String?                   @map("redacted_value")
  expiresAt         DateTime?                 @map("expires_at")
  lastRotatedAt     DateTime?                 @map("last_rotated_at")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  providerConfig    IntegrationProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@unique([providerConfigId, kind])
  @@index([expiresAt])
  @@map("integration_credentials")
}

model IntegrationSyncState {
  id                String                    @id @default(uuid())
  providerConfigId  String                    @map("provider_config_id")
  scope             String
  status            IntegrationSyncStatus     @default(IDLE)
  cursor            String?
  nextSyncAt        DateTime?                 @map("next_sync_at")
  lastSyncedAt      DateTime?                 @map("last_synced_at")
  startedAt         DateTime?                 @map("started_at")
  finishedAt        DateTime?                 @map("finished_at")
  lastErrorCode     String?                   @map("last_error_code")
  lastErrorMessage  String?                   @map("last_error_message")
  metadata          Json?
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  providerConfig    IntegrationProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@unique([providerConfigId, scope])
  @@index([status, nextSyncAt])
  @@map("integration_sync_states")
}

model IntegrationEntityMapping {
  id                String                    @id @default(uuid())
  providerConfigId  String                    @map("provider_config_id")
  entityType        String                    @map("entity_type")
  direction         IntegrationMappingDirection @default(BIDIRECTIONAL)
  internalId        String                    @map("internal_id")
  externalId        String                    @map("external_id")
  externalUpdatedAt DateTime?                 @map("external_updated_at")
  metadata          Json?
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  providerConfig    IntegrationProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@unique([providerConfigId, entityType, internalId], map: "integration_entity_mappings_internal_unique")
  @@unique([providerConfigId, entityType, externalId], map: "integration_entity_mappings_external_unique")
  @@index([providerConfigId, entityType, direction])
  @@map("integration_entity_mappings")
}

/// Partial UNIQUE indexes and subject nullability checks are enforced in SQL migration files
/// because Prisma schema cannot express those PostgreSQL-specific invariants directly.
model CapacitySchedule {
  id            String                      @id @default(uuid())
  workspaceId    String                     @map("workspace_id")
  subjectType    CapacityScheduleSubjectType @map("subject_type")
  subjectUserId  String?                    @map("subject_user_id")
  name          String
  timeZone      String                      @map("time_zone")
  hoursPerDay   Int                         @map("hours_per_day")
  daysOfWeek    Int[]                       @default([]) @map("days_of_week")
  createdAt     DateTime                    @default(now()) @map("created_at")
  updatedAt     DateTime                    @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subjectUser User?     @relation(fields: [subjectUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId, subjectType, createdAt])
  @@index([subjectUserId, createdAt])
  @@map("capacity_schedules")
}

model TimeOffEvent {
  id             String   @id @default(uuid())
  workspaceId     String   @map("workspace_id")
  userId         String   @map("user_id")
  startDate      DateTime @db.Date @map("start_date")
  endDate        DateTime @db.Date @map("end_date")
  minutesPerDay  Int      @map("minutes_per_day")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId, startDate, endDate])
  @@map("time_off_events")
}

model WorkspaceMembership {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(WS_MEMBER)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Invitation {
  id              String   @id @default(uuid())
  workspaceId     String
  email           String
  role            WorkspaceRole @default(WS_MEMBER)
  tokenHash       String   @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdByUserId String
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User @relation("InvitationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, email])
}

model Project {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberships ProjectMembership[]
  sections    Section[]
  tasks       Task[]
  taskLinks   TaskProjectLink[]
  rules       Rule[]
  webhooks    Webhook[]
  portfolios  PortfolioProject[]
  notifications InboxNotification[]
  customFieldDefinitions CustomFieldDefinition[]
  statusUpdates ProjectStatusUpdate[]
  recurringRules RecurringRule[]
  forms       Form[]
  timelinePreferences ProjectTimelinePreference[]
  viewPreferences ProjectViewPreference[]
  savedViews ProjectSavedView[]
  followers   ProjectFollower[]
  goalLinks   GoalProjectLink[]
}

model Goal {
  id              String      @id @default(uuid())
  workspaceId      String      @map("workspace_id")
  ownerUserId      String      @map("owner_user_id")
  title           String
  description     String?
  status          GoalStatus   @default(NOT_STARTED)
  progressPercent Int          @default(0) @map("progress_percent")
  archivedAt      DateTime?    @map("archived_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner     User      @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  projectLinks GoalProjectLink[]

  @@index([workspaceId, archivedAt, createdAt])
  @@index([ownerUserId, archivedAt])
  @@map("goals")
}

model ProjectStatusUpdate {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  authorUserId String  @map("author_user_id")
  health      ProjectStatusHealth
  summary     String
  blockers    String[] @default([])
  nextSteps   String[] @default([]) @map("next_steps")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  notifications InboxNotification[]

  @@index([projectId, createdAt])
  @@map("project_status_updates")
}

model ProjectMembership {
  id          String      @id @default(uuid())
  projectId   String
  userId      String
  role        ProjectRole
  createdAt   DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectTimelinePreference {
  id                  String   @id @default(uuid())
  projectId           String
  userId              String
  laneOrderBySection  String[] @default([])
  laneOrderByAssignee String[] @default([])
  taskOrderBySection  Json?
  taskOrderByAssignee Json?
  taskOrderByStatus   Json?
  timelineManualLayout Json?
  timelineViewState   Json?
  ganttViewState      Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectViewPreference {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  mode      String
  state     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, mode])
  @@index([projectId, userId])
  @@index([userId])
  @@map("project_view_preferences")
}

model ProjectSavedView {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  name      String
  mode      String
  state     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, userId, createdAt])
  @@index([userId])
  @@map("project_saved_views")
}

model Section {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  position    Int
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
  recurringRules RecurringRule[]

  @@unique([projectId, position])
}

model Task {
  id             String     @id @default(uuid())
  projectId       String
  sectionId       String
  title          String
  description    String?
  descriptionDoc Json?      @map("description_doc")
  descriptionText String?   @map("description_text")
  descriptionUpdatedAt DateTime? @map("description_updated_at")
  descriptionVersion Int    @default(0) @map("description_version")
  status         TaskStatus @default(TODO)
  type           TaskType   @default(TASK)
  progressPercent Int       @default(0)
  priority       Priority?
  assigneeUserId String?
  startAt        DateTime?
  dueAt          DateTime?
  baselineStartAt DateTime?
  baselineDueAt   DateTime?
  tags           String[]   @default([])
  completedAt    DateTime?
  deletedAt      DateTime?  @map("deleted_at")
  deletedByUserId String?   @map("deleted_by_user_id")
  position       Int
  version        Int        @default(1)
  estimateMinutes Int?      @map("estimate_minutes")
  spentMinutes   Int        @default(0) @map("spent_minutes")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  projectLinks TaskProjectLink[]
  comments TaskComment[]
  mentions TaskMention[]
  notifications InboxNotification[]
  attachments TaskAttachment[]
  reminders TaskReminder[]
  followers TaskFollower[]
  
  // Subtask hierarchy (up to 5 levels)
  parentId String?
  parent   Task?    @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Task[]   @relation("TaskHierarchy")
  
  // Dependencies
  dependencies TaskDependency[] @relation("TaskDependencies")
  dependents   TaskDependency[] @relation("TaskDependents")
  customFieldValues TaskCustomFieldValue[]
  recurringRule RecurringRule? @relation(fields: [recurringRuleId], references: [id])
  recurringRuleId String?
  sourceRecurringRule RecurringRule? @relation("RecurringRuleSourceTask")
  recurringGeneration RecurringTaskGeneration?
  formSubmission FormSubmission?
  approval TaskApproval?
  timeLogs TaskTimeLog[]

  @@index([projectId, sectionId, position])
  @@index([projectId, sectionId, deletedAt, position])
  @@index([parentId])
  @@index([projectId, deletedAt])
  @@index([projectId, deletedAt, status, assigneeUserId, dueAt])
  @@index([projectId, deletedAt, updatedAt])
  @@index([projectId, deletedAt, type])
  @@index([projectId, deletedAt, startAt])
  @@index([projectId, deletedAt, baselineStartAt])
  @@index([projectId, deletedAt, baselineDueAt])
  @@index([recurringRuleId])
}

model TaskFollower {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId, createdAt])
  @@index([userId, createdAt])
  @@map("task_followers")
}

model ProjectFollower {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId, createdAt])
  @@index([userId, createdAt])
  @@map("project_followers")
}

model GoalProjectLink {
  id        String    @id @default(uuid())
  goalId    String    @map("goal_id")
  projectId String    @map("project_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  goal    Goal    @relation(fields: [goalId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([goalId, projectId])
  @@index([goalId, deletedAt, createdAt])
  @@index([projectId, deletedAt])
  @@map("goal_project_links")
}

model TaskProjectLink {
  id        String    @id @default(uuid())
  taskId    String    @map("task_id")
  projectId String    @map("project_id")
  isPrimary Boolean   @default(false) @map("is_primary")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([taskId, projectId])
  @@index([taskId])
  @@index([taskId, deletedAt])
  @@index([projectId, deletedAt])
  @@index([taskId, deletedAt, isPrimary])
  @@map("task_project_links")
}

model TaskApproval {
  id          String             @id @default(uuid())
  taskId      String             @unique @map("task_id")
  status      TaskApprovalStatus @default(PENDING)
  approverUserId String?         @map("approver_user_id")
  comment     String?
  requestedAt DateTime           @default(now()) @map("requested_at")
  respondedAt DateTime?          @map("responded_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  approver User? @relation(fields: [approverUserId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([approverUserId])
  @@map("task_approvals")
}

model TaskTimeLog {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  userId      String   @map("user_id")
  minutes     Int
  description String?
  loggedAt    DateTime @default(now()) @map("logged_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, loggedAt])
  @@index([userId, loggedAt])
  @@map("task_time_logs")
}

model CustomFieldDefinition {
  id          String          @id @default(uuid())
  projectId   String          @map("project_id")
  name        String
  type        CustomFieldType
  description String?
  required    Boolean         @default(false)
  position    Int             @default(1000)
  archivedAt  DateTime?       @map("archived_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  options CustomFieldOption[]
  values  TaskCustomFieldValue[]

  @@index([projectId, archivedAt, position])
  @@map("custom_field_definitions")
}

model CustomFieldOption {
  id         String    @id @default(uuid())
  fieldId    String    @map("field_id")
  label      String
  value      String
  color      String?
  position   Int       @default(1000)
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  field  CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  values TaskCustomFieldValue[]

  @@unique([fieldId, value])
  @@index([fieldId, archivedAt, position])
  @@map("custom_field_options")
}

model TaskCustomFieldValue {
  id           String    @id @default(uuid())
  taskId       String    @map("task_id")
  fieldId      String    @map("field_id")
  optionId     String?   @map("option_id")
  valueText    String?   @map("value_text")
  valueNumber  Decimal?  @map("value_number")
  valueDate    DateTime? @map("value_date")
  valueBoolean Boolean?  @map("value_boolean")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  task   Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  field  CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  option CustomFieldOption?    @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([taskId, fieldId])
  @@index([fieldId])
  @@index([optionId])
  @@map("task_custom_field_values")
}

model InboxNotification {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  projectId         String    @map("project_id")
  taskId            String?   @map("task_id")
  statusUpdateId    String?   @map("status_update_id")
  type              String
  sourceType        String    @map("source_type")
  sourceId          String    @default("") @map("source_id")
  triggeredByUserId String?   @map("triggered_by_user_id")
  readAt            DateTime? @map("read_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  statusUpdate ProjectStatusUpdate? @relation(fields: [statusUpdateId], references: [id], onDelete: Cascade)
  triggeredBy User? @relation("NotificationTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([userId, readAt, createdAt])
  @@index([projectId, taskId])
  @@index([projectId, statusUpdateId])
  @@unique([userId, projectId, type, sourceType, sourceId])
  @@map("inbox_notifications")
}

model TaskReminder {
  id         String    @id @default(uuid())
  taskId     String    @map("task_id")
  userId     String    @map("user_id")
  remindAt   DateTime  @map("remind_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  sentAt     DateTime? @map("sent_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, userId])
  @@index([taskId, userId, deletedAt])
  @@map("task_reminders")
}

model UserReminderPreference {
  id                     String   @id @default(uuid())
  userId                 String   @unique @map("user_id")
  enabled                Boolean  @default(true)
  defaultLeadTimeMinutes Int      @default(60) @map("default_lead_time_minutes")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_reminder_preferences")
}

model TaskComment {
  id           String   @id @default(uuid())
  taskId       String   @map("task_id")
  authorUserId String   @map("author_user_id")
  body         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([taskId, deletedAt, createdAt])
  @@map("task_comments")
}

model TaskMention {
  id              String   @id @default(uuid())
  taskId          String   @map("task_id")
  mentionedUserId String   @map("mentioned_user_id")
  sourceType      String   @map("source_type")
  sourceId        String   @default("") @map("source_id")
  createdAt       DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, sourceType, sourceId])
  @@unique([taskId, mentionedUserId, sourceType, sourceId])
  @@map("task_mentions")
}

model TaskAttachment {
  id             String   @id @default(uuid())
  taskId         String   @map("task_id")
  uploaderUserId String   @map("uploader_user_id")
  fileName       String   @map("file_name")
  mimeType       String   @map("mime_type")
  sizeBytes      Int      @map("size_bytes")
  storageKey     String   @map("storage_key")
  uploadToken    String?  @map("upload_token")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([taskId, deletedAt, createdAt])
  @@map("task_attachments")
}

model Rule {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  templateKey String
  definition  Json?
  enabled     Boolean  @default(true)
  cooldownSec Int      @default(60)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    RuleRun[]

  @@unique([projectId, templateKey])
}

model RuleRun {
  id            String   @id @default(uuid())
  ruleId         String
  taskId         String
  changed        Boolean
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  correlationId String

  rule Rule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, taskId, startedAt])
}

model AuditEvent {
  id            String   @id @default(uuid())
  actor         String
  entityType    String
  entityId      String
  action        String
  beforeJson    Json?
  afterJson     Json?
  correlationId String
  createdAt     DateTime @default(now())

  @@index([entityType, entityId, createdAt])
}

model OutboxEvent {
  id            String   @id @default(uuid())
  type          String
  payload       Json
  correlationId String
  createdAt     DateTime @default(now())
  deliveredAt   DateTime?
  deliveryAttempts Int     @default(0) @map("delivery_attempts")
  nextRetryAt      DateTime? @map("next_retry_at")
  deadLetteredAt   DateTime? @map("dead_lettered_at")
  lastError        String?   @map("last_error")

  @@index([type, createdAt])
  @@index([nextRetryAt, deadLetteredAt, deliveredAt])
}

model Webhook {
  id          String   @id @default(uuid())
  projectId   String
  targetUrl   String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}


model TaskDependency {
  id          String @id @default(uuid())
  taskId      String
  dependsOnId String
  type        DependencyType @default(BLOCKS)
  
  task      Task @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
  @@index([taskId, createdAt])
  @@index([dependsOnId, createdAt])
}


model Portfolio {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects  PortfolioProject[]

  @@index([workspaceId])
  @@map("portfolios")
}

model PortfolioProject {
  portfolioId String @map("portfolio_id")
  projectId   String @map("project_id")
  
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@id([portfolioId, projectId])
  @@index([portfolioId])
  @@index([projectId])
  @@map("portfolio_projects")
}

model Dashboard {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  layout      Json     // Widget positions
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets Widget[]

  @@index([userId])
  @@map("dashboards")
}

model Widget {
  id          String @id @default(uuid())
  dashboardId String @map("dashboard_id")
  type        WidgetType
  config      Json
  position    Json // { x, y, w, h }
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@map("widgets")
}

enum WidgetType {
  TASK_COMPLETION
  PROGRESS_CHART
  TEAM_LOAD
  OVERDUE_ALERTS
  RECENT_ACTIVITY
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model RecurringRule {
  id          String   @id @default(uuid())
  projectId   String
  sourceTaskId String? @unique
  title       String
  description String?
  frequency   RecurringFrequency
  interval    Int      @default(1)
  daysOfWeek  Int[]    @default([])
  dayOfMonth  Int?
  sectionId   String
  assigneeUserId String?
  priority    Priority?
  tags        String[] @default([])
  startDate   DateTime
  endDate     DateTime?
  lastGeneratedAt DateTime?
  nextScheduledAt DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceTask Task? @relation("RecurringRuleSourceTask", fields: [sourceTaskId], references: [id], onDelete: SetNull)
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  tasks     Task[]
  generations RecurringTaskGeneration[]

  @@index([projectId, isActive])
  @@index([isActive, nextScheduledAt])
}

model RecurringTaskGeneration {
  id          String   @id @default(uuid())
  ruleId      String
  taskId      String?   @unique
  scheduledAt DateTime
  generatedAt DateTime @default(now())
  status      String   @default("completed")
  error       String?
  retryCount  Int      @default(0)

  rule RecurringRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([ruleId, scheduledAt])
  @@index([status, retryCount])
}

enum FormQuestionType {
  TEXT
  TEXTAREA
  NUMBER
  EMAIL
  SELECT
  MULTI_SELECT
  DATE
  CHECKBOX
}

model Form {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  title       String
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  publicToken String?  @unique @map("public_token")
  createdByUserId String @map("created_by_user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  archivedAt  DateTime? @map("archived_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  questions FormQuestion[]
  submissions FormSubmission[]

  @@index([projectId, archivedAt])
  @@map("forms")
}

model FormQuestion {
  id          String   @id @default(uuid())
  formId      String   @map("form_id")
  type        FormQuestionType
  label       String
  description String?
  required    Boolean  @default(false)
  options     Json?    // For SELECT/MULTI_SELECT: [{label, value}]
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers FormAnswer[]

  @@index([formId, position])
  @@map("form_questions")
}

model FormSubmission {
  id          String   @id @default(uuid())
  formId      String   @map("form_id")
  submitterName String @map("submitter_name")
  submitterEmail String @map("submitter_email")
  createdTaskId String? @unique @map("created_task_id")
  createdAt   DateTime @default(now()) @map("created_at")

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)
  createdTask Task? @relation(fields: [createdTaskId], references: [id], onDelete: SetNull)
  answers FormAnswer[]

  @@index([formId, createdAt])
  @@map("form_submissions")
}

model FormAnswer {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  questionId   String   @map("question_id")
  valueText    String?  @map("value_text")
  valueNumber  Decimal? @map("value_number")
  valueBoolean Boolean? @map("value_boolean")
  valueJson    Json?    @map("value_json") // For arrays (multi-select)
  createdAt    DateTime @default(now()) @map("created_at")

  submission FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   FormQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId])
  @@map("form_answers")
}
