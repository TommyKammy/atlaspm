generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectRole {
  ADMIN
  MEMBER
  VIEWER
}

enum WorkspaceRole {
  WS_ADMIN
  WS_MEMBER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum TaskType {
  TASK
  MILESTONE
  APPROVAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DependencyType {
  BLOCKS
  BLOCKED_BY
  RELATES_TO
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  BOOLEAN
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  projects    Project[]
  memberships WorkspaceMembership[]
  invitations Invitation[]
  portfolios  Portfolio[]
}

model User {
  id          String   @id
  email       String?
  displayName String?
  status      UserStatus @default(ACTIVE)
  lastSeenAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspaceMemberships WorkspaceMembership[]
  projectMemberships   ProjectMembership[]
  invitationsCreated   Invitation[] @relation("InvitationCreatedBy")
  notifications        InboxNotification[]
  triggeredNotifications InboxNotification[] @relation("NotificationTriggeredBy")
  dashboards           Dashboard[]
  reminders            TaskReminder[]
  statusUpdates        ProjectStatusUpdate[]
}

model WorkspaceMembership {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(WS_MEMBER)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Invitation {
  id              String   @id @default(uuid())
  workspaceId     String
  email           String
  role            WorkspaceRole @default(WS_MEMBER)
  tokenHash       String   @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdByUserId String
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User @relation("InvitationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, email])
}

model Project {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberships ProjectMembership[]
  sections    Section[]
  tasks       Task[]
  rules       Rule[]
  webhooks    Webhook[]
  portfolios  PortfolioProject[]
  notifications InboxNotification[]
  customFieldDefinitions CustomFieldDefinition[]
  statusUpdates ProjectStatusUpdate[]
  recurringRules RecurringRule[]
}

model ProjectStatusUpdate {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  authorUserId String  @map("author_user_id")
  body        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_status_updates")
}

model ProjectMembership {
  id          String      @id @default(uuid())
  projectId   String
  userId      String
  role        ProjectRole
  createdAt   DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Section {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  position    Int
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
  recurringRules RecurringRule[]

  @@unique([projectId, position])
}

model Task {
  id             String     @id @default(uuid())
  projectId       String
  sectionId       String
  title          String
  description    String?
  descriptionDoc Json?      @map("description_doc")
  descriptionText String?   @map("description_text")
  descriptionUpdatedAt DateTime? @map("description_updated_at")
  descriptionVersion Int    @default(0) @map("description_version")
  status         TaskStatus @default(TODO)
  type           TaskType   @default(TASK)
  progressPercent Int       @default(0)
  priority       Priority?
  assigneeUserId String?
  startAt        DateTime?
  dueAt          DateTime?
  tags           String[]   @default([])
  completedAt    DateTime?
  deletedAt      DateTime?  @map("deleted_at")
  deletedByUserId String?   @map("deleted_by_user_id")
  position       Int
  version        Int        @default(1)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  comments TaskComment[]
  mentions TaskMention[]
  notifications InboxNotification[]
  attachments TaskAttachment[]
  reminders TaskReminder[]
  
  // Subtask hierarchy (up to 5 levels)
  parentId String?
  parent   Task?    @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Task[]   @relation("TaskHierarchy")
  
  // Dependencies
  dependencies TaskDependency[] @relation("TaskDependencies")
  dependents   TaskDependency[] @relation("TaskDependents")
  customFieldValues TaskCustomFieldValue[]
  recurringRule RecurringRule? @relation(fields: [recurringRuleId], references: [id])
  recurringRuleId String?
  recurringGeneration RecurringTaskGeneration?

  @@index([projectId, sectionId, position])
  @@index([projectId, sectionId, deletedAt, position])
  @@index([parentId])
  @@index([projectId, deletedAt])
  @@index([projectId, deletedAt, status, assigneeUserId, dueAt])
  @@index([projectId, deletedAt, updatedAt])
  @@index([projectId, deletedAt, type])
  @@index([recurringRuleId])
}

model CustomFieldDefinition {
  id          String          @id @default(uuid())
  projectId   String          @map("project_id")
  name        String
  type        CustomFieldType
  description String?
  required    Boolean         @default(false)
  position    Int             @default(1000)
  archivedAt  DateTime?       @map("archived_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  options CustomFieldOption[]
  values  TaskCustomFieldValue[]

  @@index([projectId, archivedAt, position])
  @@map("custom_field_definitions")
}

model CustomFieldOption {
  id         String    @id @default(uuid())
  fieldId    String    @map("field_id")
  label      String
  value      String
  color      String?
  position   Int       @default(1000)
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  field  CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  values TaskCustomFieldValue[]

  @@unique([fieldId, value])
  @@index([fieldId, archivedAt, position])
  @@map("custom_field_options")
}

model TaskCustomFieldValue {
  id           String    @id @default(uuid())
  taskId       String    @map("task_id")
  fieldId      String    @map("field_id")
  optionId     String?   @map("option_id")
  valueText    String?   @map("value_text")
  valueNumber  Decimal?  @map("value_number")
  valueDate    DateTime? @map("value_date")
  valueBoolean Boolean?  @map("value_boolean")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  task   Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  field  CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  option CustomFieldOption?    @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([taskId, fieldId])
  @@index([fieldId])
  @@index([optionId])
  @@map("task_custom_field_values")
}

model InboxNotification {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  projectId         String    @map("project_id")
  taskId            String    @map("task_id")
  type              String
  sourceType        String    @map("source_type")
  sourceId          String    @default("") @map("source_id")
  triggeredByUserId String?   @map("triggered_by_user_id")
  readAt            DateTime? @map("read_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  triggeredBy User? @relation("NotificationTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([userId, readAt, createdAt])
  @@index([projectId, taskId])
  @@unique([userId, taskId, type, sourceType, sourceId])
  @@map("inbox_notifications")
}

model TaskReminder {
  id         String    @id @default(uuid())
  taskId     String    @map("task_id")
  userId     String    @map("user_id")
  remindAt   DateTime  @map("remind_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  sentAt     DateTime? @map("sent_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, userId])
  @@index([taskId, userId, deletedAt])
  @@map("task_reminders")
}

model TaskComment {
  id           String   @id @default(uuid())
  taskId       String   @map("task_id")
  authorUserId String   @map("author_user_id")
  body         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([taskId, deletedAt, createdAt])
  @@map("task_comments")
}

model TaskMention {
  id              String   @id @default(uuid())
  taskId          String   @map("task_id")
  mentionedUserId String   @map("mentioned_user_id")
  sourceType      String   @map("source_type")
  sourceId        String   @default("") @map("source_id")
  createdAt       DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, sourceType, sourceId])
  @@unique([taskId, mentionedUserId, sourceType, sourceId])
  @@map("task_mentions")
}

model TaskAttachment {
  id             String   @id @default(uuid())
  taskId         String   @map("task_id")
  uploaderUserId String   @map("uploader_user_id")
  fileName       String   @map("file_name")
  mimeType       String   @map("mime_type")
  sizeBytes      Int      @map("size_bytes")
  storageKey     String   @map("storage_key")
  uploadToken    String?  @map("upload_token")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([taskId, deletedAt, createdAt])
  @@map("task_attachments")
}

model Rule {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  templateKey String
  definition  Json?
  enabled     Boolean  @default(true)
  cooldownSec Int      @default(60)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    RuleRun[]

  @@unique([projectId, templateKey])
}

model RuleRun {
  id            String   @id @default(uuid())
  ruleId         String
  taskId         String
  changed        Boolean
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  correlationId String

  rule Rule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, taskId, startedAt])
}

model AuditEvent {
  id            String   @id @default(uuid())
  actor         String
  entityType    String
  entityId      String
  action        String
  beforeJson    Json?
  afterJson     Json?
  correlationId String
  createdAt     DateTime @default(now())

  @@index([entityType, entityId, createdAt])
}

model OutboxEvent {
  id            String   @id @default(uuid())
  type          String
  payload       Json
  correlationId String
  createdAt     DateTime @default(now())
  deliveredAt   DateTime?
  deliveryAttempts Int     @default(0) @map("delivery_attempts")
  nextRetryAt      DateTime? @map("next_retry_at")
  deadLetteredAt   DateTime? @map("dead_lettered_at")
  lastError        String?   @map("last_error")

  @@index([type, createdAt])
  @@index([nextRetryAt, deadLetteredAt, deliveredAt])
}

model Webhook {
  id          String   @id @default(uuid())
  projectId   String
  targetUrl   String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}


model TaskDependency {
  id          String @id @default(uuid())
  taskId      String
  dependsOnId String
  type        DependencyType @default(BLOCKS)
  
  task      Task @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
}


model Portfolio {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects  PortfolioProject[]

  @@index([workspaceId])
  @@map("portfolios")
}

model PortfolioProject {
  portfolioId String @map("portfolio_id")
  projectId   String @map("project_id")
  
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@id([portfolioId, projectId])
  @@index([portfolioId])
  @@index([projectId])
  @@map("portfolio_projects")
}

model Dashboard {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  layout      Json     // Widget positions
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets Widget[]

  @@index([userId])
  @@map("dashboards")
}

model Widget {
  id          String @id @default(uuid())
  dashboardId String @map("dashboard_id")
  type        WidgetType
  config      Json
  position    Json // { x, y, w, h }
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@map("widgets")
}

enum WidgetType {
  TASK_COMPLETION
  PROGRESS_CHART
  TEAM_LOAD
  OVERDUE_ALERTS
  RECENT_ACTIVITY
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model RecurringRule {
  id          String   @id @default(uuid())
  projectId   String
  title       String
  description String?
  frequency   RecurringFrequency
  interval    Int      @default(1)
  daysOfWeek  Int[]    @default([])
  dayOfMonth  Int?
  sectionId   String
  assigneeUserId String?
  priority    Priority?
  tags        String[] @default([])
  startDate   DateTime
  endDate     DateTime?
  lastGeneratedAt DateTime?
  nextScheduledAt DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  tasks     Task[]
  generations RecurringTaskGeneration[]

  @@index([projectId, isActive])
  @@index([isActive, nextScheduledAt])
}

model RecurringTaskGeneration {
  id          String   @id @default(uuid())
  ruleId      String
  taskId      String?   @unique
  scheduledAt DateTime
  generatedAt DateTime @default(now())
  status      String   @default("completed")
  error       String?
  retryCount  Int      @default(0)

  rule RecurringRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([ruleId, scheduledAt])
  @@index([status, retryCount])
}
