NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://atlaspm:atlaspm@localhost:55432/atlaspm?schema=public
OIDC_ISSUER=https://example.okta.com/oauth2/default
OIDC_AUDIENCE=atlaspm
OIDC_JWKS_URI=https://example.okta.com/oauth2/default/v1/keys
DEV_AUTH_ENABLED=false
DEV_AUTH_SECRET=dev-secret-change-me
DEV_AUTH_TOKEN_TTL=8h
COLLAB_JWT_SECRET=collab-jwt-secret-change-me
COLLAB_SERVICE_TOKEN=collab-service-token-change-me
COLLAB_SERVER_URL=ws://localhost:18080
COLLAB_TOKEN_TTL_SEC=600
REMINDER_WORKER_ENABLED=true
REMINDER_WORKER_INTERVAL_MS=30000
REMINDER_WORKER_BATCH_SIZE=50
TASK_RETENTION_WORKER_ENABLED=false
TASK_RETENTION_WORKER_INTERVAL_MS=3600000
TASK_RETENTION_DAYS=30
TASK_RETENTION_BATCH_SIZE=100
WEBHOOK_DELIVERY_WORKER_ENABLED=false
WEBHOOK_DELIVERY_INTERVAL_MS=15000
WEBHOOK_DELIVERY_BATCH_SIZE=25
WEBHOOK_DELIVERY_MAX_ATTEMPTS=5
WEBHOOK_DELIVERY_BASE_DELAY_MS=5000
WEBHOOK_DELIVERY_MAX_DELAY_MS=60000
WEBHOOK_DELIVERY_REQUEST_TIMEOUT_MS=8000
WEBHOOK_SIGNING_SECRET=change-me-webhook-signing-secret
INVITE_BASE_URL=http://localhost:3000/login

# Search backend toggle (set false for deterministic local/CI tests)
SEARCH_ENABLED=false

# Algolia Search Configuration (optional - required only when SEARCH_ENABLED=true)
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
